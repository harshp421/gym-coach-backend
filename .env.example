# ============================================================================
# Gym Coach — backend env. Copy to `.env` and fill in. Never commit `.env`.
# Validated at boot by src/config/env.config.ts — missing required vars
# crash the process with a clear zod error.
# ============================================================================

# --- REQUIRED ---------------------------------------------------------------

# Postgres connection. Neon, Supabase, Render, or local Docker all work.
# Append `?sslmode=require` for hosted DBs.
GYM_POSTGRES_URI=postgres://user:pass@host/db?sslmode=require

# Signing key for session JWTs (HS256). 32+ bytes of entropy.
# Generate: `openssl rand -hex 32`
GYM_JWT_SECRET=replace-with-32-plus-byte-random-string

# `development` | `production` | `test`. Drives SSL, cookie flags, docs, etc.
GYM_ENVIRONMENT=development

# Port the API listens on. Frontend's VITE_API_URL must point here.
PORT=3000

# Email via SMTP (nodemailer). All four are REQUIRED — without them the
# worker can't send verification / password-reset / coach notifications.
#
# Gmail setup:
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-char App Password (NO spaces) into SMTP_PASS
#   4. SMTP_USER = the Gmail address; EMAIL_FROM should match it (Gmail
#      rewrites the From header to the authenticated user otherwise).
#
# Other providers:
#   Outlook:   smtp-mail.outlook.com:587
#   iCloud:    smtp.mail.me.com:587 (app-specific password)
#   Yahoo:     smtp.mail.yahoo.com:465
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=replace-with-16-char-app-password
EMAIL_FROM=you@gmail.com

# --- OPTIONAL ---------------------------------------------------------------

# Frontend origin — used for CORS allow-list and the links inside emails.
# Defaults to http://localhost:5173 if unset.
FRONTEND_URL=http://localhost:5173

# AI coach + diet plan generation (Groq). Missing key → /coach and
# /diet/plan/generate return 503. The two model defaults work as-is.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google sign-in. Missing → /auth/oauth returns 501. Register the client
# at console.cloud.google.com → Credentials → OAuth 2.0 → Web app, with
# FRONTEND_URL listed under "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=

# Upstash Redis (REST API). When set, used for distributed cache + rate
# limiting. Missing → in-process fallback (cache becomes a per-instance
# LRU, rate-limit a per-instance counter). Fine for local dev / single
# instance, required for horizontally-scaled deploys.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Force-enable Swagger UI at /docs in production. Without this, /docs is
# only mounted when GYM_ENVIRONMENT != "production".
GYM_DOCS_ENABLED=
