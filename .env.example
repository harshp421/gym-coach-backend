# Required
GYM_POSTGRES_URI=postgres://user:pass@host/db?sslmode=require
GYM_JWT_SECRET=run-`openssl rand -hex 32`-to-generate
GYM_ENVIRONMENT=development
PORT=3000

# Optional — frontend origin for CORS + email links. Defaults to localhost:5173.
FRONTEND_URL=http://localhost:5173

# Optional — email sending. Missing RESEND_API_KEY → falls back to console.log.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Optional — AI coach (Groq). Missing key → /coach endpoints return 503.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional — Google OAuth. Missing → /auth/oauth returns 501.
# The (client_id, origin) pair must be registered in Google Cloud Console
# under "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=

# Optional — Upstash Redis (REST API). When set, used for cross-instance
# caching (exercise catalog) and rate limiting. Missing → in-process
# fallback (cache becomes a per-instance LRU, rate-limit a per-instance
# counter).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — force-enable Swagger UI at /docs in production. Without this
# /docs is only mounted when GYM_ENVIRONMENT != "production".
GYM_DOCS_ENABLED=
