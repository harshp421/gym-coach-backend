{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "esnext",
    // For nodejs. `dom` is included for HeadersInit (used by the Resend
    // SDK's typings).
    "lib": ["esnext", "dom"],
    "types": ["node"],

    // Resend's types reference React for their email components (which
    // we don't use). skipLibCheck keeps third-party type leakage out of
    // our typecheck.
    "skipLibCheck": true,

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true

    // Stricter Typechecking Options

  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "migration"]
}
